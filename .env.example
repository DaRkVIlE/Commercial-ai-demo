# Experia Demo Bots — Environment Variables
# NEVER commit this file with real keys

# Groq API Keys (fallback chain: 1 → 2 → 3)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Server
PORT=8080
NODE_ENV=production

# Security
SESSION_SECRET=change-me-to-a-random-string
ALLOWED_ORIGIN=*
MAX_MESSAGES_PER_SESSION=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
